# PeruRE Agent Environment Configuration
# Copy to .env and fill in real values

# Anthropic API (Required)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Mapbox (Required for routing and maps)
# Get free token at https://account.mapbox.com/access-tokens
MAPBOX_TOKEN=pk.xxxxx

# Google Maps Directions API (Optional - enables transit mode)
# $200 free monthly credit. Enable Directions API in GCP console.
GOOGLE_MAPS_API_KEY=AIzaxxxxx

# WhatsApp Business API (Required for messaging)
# Get from Meta Business Platform
WHATSAPP_BUSINESS_TOKEN=EAAXxxxx
WHATSAPP_PHONE_NUMBER_ID=1555xxxx

# PostgreSQL (Required for property_db and calendar)
DATABASE_URL=postgresql://peru_re:password@localhost:5432/peru_re_db

# Broker ID (for single-broker demo)
BROKER_ID=broker_demo_001
